# Copy this file to .env and fill in values before running locally.
# Never commit .env — it is gitignored.

# Token used to authenticate incoming moderation requests.
# Must match the token sent in the ZulipRequest payload.
MODERATION_TOKEN=your_secret_token_here

# Zulip bot credentials — create a bot in your Zulip org settings.
ZULIP_SITE=https://your-org.zulipchat.com
ZULIP_BOT_EMAIL=moderation-bot@your-org.zulipchat.com
ZULIP_BOT_API_KEY=your_bot_api_key_here
ZULIP_ADMIN_EMAIL=admin@your-org.zulipchat.com

# Chameleon S3 — object storage for raw/cleaned data and training sets.
S3_ENDPOINT=chi.tacc.chameleoncloud.org:7480
S3_ACCESS_KEY=your_chameleon_ec2_access_key
S3_SECRET_KEY=your_chameleon_ec2_secret_key
S3_SECURE=true

# PostgreSQL — message and flag persistence.
DATABASE_URL=postgresql://user:chatsentry_pg@localhost:5432/chatsentry

# MLflow — experiment tracking for training runs.
MLFLOW_TRACKING_URI=http://localhost:5000
